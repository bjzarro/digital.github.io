<!-- TOAST -->
<div id="toast" class="fixed bottom-24 right-6 z-[60] translate-y-4 opacity-0 pointer-events-none transition-all duration-300 bg-brand-green text-black font-semibold text-sm px-4 py-3 rounded-xl shadow-glow flex items-center gap-2">
  <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M5 13l4 4L19 7"/></svg>
  <span id="toastMsg">E-mail copiado!</span>
</div>

<script>
  document.getElementById('yr').textContent = new Date().getFullYear();

  (function() {
    const btn = document.getElementById('copyEmailBtn');
    if (!btn) return;
    const toast = document.getElementById('toast');
    const toastMsg = document.getElementById('toastMsg');
    const iconMail = btn.querySelector('.icon-mail');
    const iconCheck = btn.querySelector('.icon-check');
    const hint = btn.querySelector('.copy-hint');
    const originalHint = hint.textContent;

    function showToast(msg) {
      toastMsg.textContent = msg;
      toast.classList.remove('translate-y-4', 'opacity-0');
      toast.classList.add('translate-y-0', 'opacity-100');
      clearTimeout(showToast._t);
      showToast._t = setTimeout(() => {
        toast.classList.add('translate-y-4', 'opacity-0');
        toast.classList.remove('translate-y-0', 'opacity-100');
      }, 2200);
    }

    function fallbackCopy(text) {
      const ta = document.createElement('textarea');
      ta.value = text;
      ta.setAttribute('readonly', '');
      ta.style.position = 'fixed';
      ta.style.opacity = '0';
      document.body.appendChild(ta);
      ta.select();
      let ok = false;
      try { ok = document.execCommand('copy'); } catch (e) {}
      document.body.removeChild(ta);
      return ok;
    }

    btn.addEventListener('click', async () => {
      const email = btn.dataset.email;
      let copied = false;
      try {
        if (navigator.clipboard && window.isSecureContext) {
          await navigator.clipboard.writeText(email);
          copied = true;
        } else {
          copied = fallbackCopy(email);
        }
      } catch (e) {
        copied = fallbackCopy(email);
      }

      if (copied) {
        iconMail.classList.add('hidden');
        iconCheck.classList.remove('hidden');
        hint.textContent = 'Copiado! Cole no seu e-mail.';
        hint.classList.add('text-brand-green');
        showToast('E-mail copiado!');
        setTimeout(() => {
          iconMail.classList.remove('hidden');
          iconCheck.classList.add('hidden');
          hint.textContent = originalHint;
          hint.classList.remove('text-brand-green');
        }, 2200);
      } else {
        showToast('Não foi possível copiar. Selecione manualmente.');
      }
    });
  })();
</script>

